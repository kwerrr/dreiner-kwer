@dp.message(CheckStates.waiting_recipient)
async def check_recipient(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if text.lower() == "skip":
        await state.update_data(recipient=None)
    else:
        username = text.lstrip("@")
        await state.update_data(recipient=username)

    balance = get_balance(message.from_user.id)
    await state.set_state(CheckStates.waiting_stars)
    await message.answer(
        f"💫 **Сколько звёзд отправить?**\n\n"
        f"💼 Доступно: **{balance} ⭐**\n"
        f"Введите число от 1 до {balance}:",
        reply_markup=cancel_kb(),
        parse_mode="Markdown"
    )

@dp.message(CheckStates.waiting_stars)
async def check_stars_amount(message: types.Message, state: FSMContext):
    try:
        amount = int(message.text.strip())
        if amount <= 0:
            raise ValueError
    except ValueError:
        await message.answer("❌ Введите корректное число звёзд.")
        return

    balance = get_balance(message.from_user.id)
    if amount > balance:
        await message.answer(f"❌ Недостаточно звёзд. Ваш баланс: **{balance} ⭐**", parse_mode="Markdown")
        return

    data = await state.get_data()
    recipient = data.get("recipient")

    if recipient:
        # Если получатель указан — спрашиваем о блокировке
        await state.update_data(stars=amount)
        await state.set_state(CheckStates.waiting_lock)
        await message.answer(
            f"🔐 **Настройка доступа к чеку**\n\n"
            f"Получатель: @{recipient}\n"
            f"Сумма: {amount} ⭐\n\n"
            f"Хотите ограничить чек только для @{recipient}?",
            reply_markup=check_lock_kb(),
            parse_mode="Markdown"
        )
    else:
        await state.update_data(stars=amount)
        await finalize_check(message, state, locked=False)

@dp.callback_query(F.data.in_({"lock_yes", "lock_no"}))
async def check_lock_choice(cb: types.CallbackQuery, state: FSMContext):
    locked = cb.data == "lock_yes"
    await cb.answer()
    await finalize_check(cb.message, state, locked=locked, user=cb.from_user)

async def finalize_check(
    message: types.Message,
    state: FSMContext,
    locked: bool,
    user: types.User = None
):
    data = await state.get_data()
    if user is None:
        user = message.from_user

    stars = data["stars"]
    recipient = data.get("recipient")

    if not deduct_stars(user.id, stars):
        await message.answer("❌ Недостаточно звёзд на балансе.")
        await state.clear()
        return

    check_id = str(uuid.uuid4())
    sender_username = user_names.get(user.id, str(user.id))

    check = {
        "id": check_id,
        "stars": stars,
        "sender": sender_username,
        "sender_id": user.id,
        "recipient": recipient,
        "locked": locked,
        "claimed": False,
        "claimed_by": None,
        "claimed_by_id": None,
        "created_at": datetime.now().isoformat(),
    }
    checks[check_id] = check

    bot_info = await bot.get_me()
    check_link = f"https://t.me/{bot_info.username}?start=check_{check_id}"

    check_text = format_check_message(check)
    await state.clear()

    # Отправляем чек создателю
    builder = InlineKeyboardBuilder()
    builder.button(text="📤 Отправить получателю", url=f"https://t.me/share/url?url={check_link}&text=Твой+чек+на+звёзды+⭐")
    builder.button(text="🔗 Скопировать ссылку", callback_data=f"copy_link_{check_id}")
    builder.adjust(1)

    await message.answer(
        f"✅ **Чек создан!**\n\n"
        f"{check_text}\n\n"
        f"🔗 **Ссылка:** `{check_link}`\n\n"
        f"_Отправьте эту ссылку получателю_",
        reply_markup=builder.as_markup(),
        parse_mode="Markdown"
    )

    # Если получатель указан — пробуем отправить уведомление (только если бот знает его chat_id)
    # В реальном боте нужна база данных с username -> chat_id
    if recipient:
        await message.answer(
            f"💌 Чтобы передать чек @{recipient}, отправьте ему ссылку выше.",
            parse_mode="Markdown"
        )

# ─── ЗАБРАТЬ ЧЕК ─────────────────────────────────────────────────────────────
async def process_check_claim(message: types.Message, check_id: str):
    check = checks.get(check_id)
    user = message.from_user
    username = user.username or str(user.id)
    user_names[user.id] = username

    if not check:
        await message.answer("❌ Чек не найден или уже использован.", parse_mode="Markdown")
        return

    if check["claimed"]:
        await message.answer(
            f"❌ **Чек уже использован**\n\n"
            f"Этот чек на {check['stars']} ⭐ уже забрал @{check['claimed_by']}.",
            parse_mode="Markdown"
        )
        return

    if check["locked"] and check.get("recipient"):
        if username.lower() != check["recipient"].lower():
            await message.answer(
                f"🔒 **Чек заблокирован**\n\n"
                f"Этот чек предназначен только для @{check['recipient']}.",
                parse_mode="Markdown"
            )
            return

    # Забираем чек
    checks[check_id]["claimed"] = True
    checks[check_id]["claimed_by"] = username
    checks[check_id]["claimed_by_id"] = user.id
    add_stars(user.id, check["stars"])
    new_balance = get_balance(user.id)

    await message.answer(
        f"🎉 **Вы забрали чек!**\n\n"
        f"╔══════════════════════╗\n"
        f"║   ⭐  ПОЛУЧЕНО  ⭐     ║\n"
        f"╚══════════════════════╝\n\n"
        f"💫 **+{check['stars']} звёзд** зачислено на ваш баланс\n"
        f"👤 От: @{check['sender']}\n"
        f"💼 Новый баланс: **{new_balance} ⭐**",
        reply_markup=main_menu_kb(),
        parse_mode="Markdown"
    )

