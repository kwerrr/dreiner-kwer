async def handle_claim_activation(update: Update, context: ContextTypes.DEFAULT_TYPE, claim_code: str):
    """Обработка перехода по ссылке с чеком"""
    user_id = update.effective_user.id
    user_username = update.effective_user.username or update.effective_user.first_name

    cursor.execute("""
        SELECT id, sender_id, sender_username, recipient_username, amount, status
        FROM pending_claims 
        WHERE claim_code = ? AND status = 'pending'
    """, (claim_code,))
    claim = cursor.fetchone()

    if not claim:
        await update.message.reply_text(
            "❌ *Чек не найден или уже использован!*",
            parse_mode=ParseMode.MARKDOWN,
            reply_markup=get_main_keyboard()
        )
        return

    claim_id, sender_id, sender_username, recipient_username, amount, status = claim

    # Проверяем, что перешедший пользователь — тот, кому предназначен чек
    if recipient_username.lower() != user_username.lower():
        await update.message.reply_text(
            "❌ *Этот чек предназначен другому пользователю!*",
            parse_mode=ParseMode.MARKDOWN,
            reply_markup=get_main_keyboard()
        )
        return

    # Сохраняем получателя в БД (чтобы потом зачислить звезды)
    cursor.execute("""
        UPDATE pending_claims SET recipient_id = ? WHERE claim_code = ?
    """, (user_id, claim_code))
    conn.commit()

    # Сохраняем в context.user_data для дальнейшего использования в WebApp
    context.user_data['claim_amount'] = amount
    context.user_data['claim_sender'] = sender_username
    context.user_data['claim_code'] = claim_code

    # Кнопка для получения звезд (ведёт на WebApp)
    keyboard = InlineKeyboardMarkup([[
        InlineKeyboardButton("⭐ Получить звезды", web_app=WebAppInfo(url=WEBAPP_URL))
    ]])

    await update.message.reply_text(
        f"🎉 *Вам отправили звезды!*\n\n"
        f"📥 Отправитель: @{sender_username}\n"
        f"⭐ Количество: `{amount:,} ★`\n\n"
        f"Для получения звезд нажмите кнопку ниже.",
        reply_markup=keyboard,
        parse_mode=ParseMode.MARKDOWN
    )

