# ─── FSM STATES ────────────────────────────────────────────────────────────────
class CheckStates(StatesGroup):
    waiting_recipient = State()
    waiting_stars = State()
    waiting_lock = State()

class BuyStates(StatesGroup):
    waiting_package = State()

# ─── IN-MEMORY STORAGE ────────────────────────────────────────────────────────
# В продакшн замените на Redis или PostgreSQL
wallets: dict[int, int] = {}          # user_id -> stars balance
checks: dict[str, dict] = {}          # check_id -> check data
user_names: dict[int, str] = {}       # user_id -> username

def get_balance(user_id: int) -> int:
    return wallets.get(user_id, 0)

def add_stars(user_id: int, amount: int):
    wallets[user_id] = wallets.get(user_id, 0) + amount

def deduct_stars(user_id: int, amount: int) -> bool:
    if wallets.get(user_id, 0) >= amount:
        wallets[user_id] -= amount
        return True
    return False

