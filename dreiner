            amount = int(parts[1])
            add_stars(message.from_user.id, amount)
            await message.answer(f"✅ Добавлено {amount} ⭐ (debug режим)")
        except ValueError:
            await message.answer("Введите число: /addstars 100")

# ─── MAIN ──────────────────────────────────────────────────────────────────────
async def main():
    logger.info("Запуск бота...")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
